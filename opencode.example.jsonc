{
  // Merge this into ~/.config/opencode/opencode.json.
  // (~ resolves to your home directory on all OSes, including Windows.)
  "$schema": "https://opencode.ai/config.json",

  // Load the plugin from its local folder. Use an absolute path or file:// URL,
  // e.g. "file:///ABSOLUTE/PATH/TO/opencode-kiro-auth".
  "plugin": ["file:///ABSOLUTE/PATH/TO/opencode-kiro-auth"],

  "provider": {
    "kiro": {
      "name": "Kiro (via kiro-cli)",
      // Driven through the Anthropic AI SDK provider; the plugin intercepts every
      // request and routes it to Kiro, so baseURL is only a placeholder.
      "npm": "@ai-sdk/anthropic",
      "options": { "baseURL": "https://kiro.local" },

      // limits/modalities mirror Kiro's ListAvailableModels. `variants` are the
      // effort levels Kiro exposes per model; they appear in opencode's variant
      // picker as labels and carry no request options, so the request is unchanged.
      "models": {
        "auto": {
          "name": "Auto (Kiro picks)",
          "limit": { "context": 1000000, "output": 64000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "claude-opus-4.8": {
          "name": "Claude Opus 4.8 (Kiro)",
          "limit": { "context": 1000000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": [{ "id": "low" }, { "id": "medium" }, { "id": "high" }, { "id": "xhigh" }, { "id": "max" }]
        },
        "claude-opus-4.7": {
          "name": "Claude Opus 4.7 (Kiro)",
          "limit": { "context": 1000000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": [{ "id": "low" }, { "id": "medium" }, { "id": "high" }, { "id": "xhigh" }, { "id": "max" }]
        },
        "claude-opus-4.6": {
          "name": "Claude Opus 4.6 (Kiro)",
          "limit": { "context": 1000000, "output": 64000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": [{ "id": "low" }, { "id": "medium" }, { "id": "high" }, { "id": "max" }]
        },
        "claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6 (Kiro)",
          "limit": { "context": 1000000, "output": 64000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": [{ "id": "low" }, { "id": "medium" }, { "id": "high" }, { "id": "max" }]
        },
        "claude-opus-4.5": {
          "name": "Claude Opus 4.5 (Kiro)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "claude-sonnet-4.5": {
          "name": "Claude Sonnet 4.5 (Kiro)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "claude-sonnet-4": {
          "name": "Claude Sonnet 4 (Kiro)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "claude-haiku-4.5": {
          "name": "Claude Haiku 4.5 (Kiro)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "deepseek-3.2": {
          "name": "DeepSeek V3.2 (Kiro)",
          "limit": { "context": 164000, "output": 64000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "minimax-m2.5": {
          "name": "MiniMax M2.5 (Kiro)",
          "limit": { "context": 196000, "output": 64000 },
          "modalities": { "input": ["text"], "output": ["text"] }
        },
        "minimax-m2.1": {
          "name": "MiniMax M2.1 (Kiro)",
          "limit": { "context": 196000, "output": 64000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "glm-5": {
          "name": "GLM-5 (Kiro)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": { "input": ["text"], "output": ["text"] }
        },
        "qwen3-coder-next": {
          "name": "Qwen3 Coder Next (Kiro)",
          "limit": { "context": 256000, "output": 64000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        }
      }
    }
  }
}
